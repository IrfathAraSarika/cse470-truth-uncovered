{
  "name": "truth-uncovered",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "setup": "npm install",
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "concurrently": "^8.2.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "typescript": "5.9.3"
  }
}
